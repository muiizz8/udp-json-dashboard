<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
	xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
	mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
	x:Class="RxGUI.Views.LogView">
	<Grid RowDefinitions="3*,2*" Margin="8" RowSpacing="8">
		<Grid ColumnDefinitions="2*,3*" ColumnSpacing="8">
			<Border Classes="card">
				<DockPanel>
					<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6">
						<TextBlock Classes="h2" Text="Logs" />
					</StackPanel>
					<dg:DataGrid ItemsSource="{Binding Logs}"
                                 SelectedItem="{Binding SelectedLog}"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 SelectionMode="Single"
                                 GridLinesVisibility="Horizontal">
						<dg:DataGrid.Columns>
							<dg:DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimeStampUtc, StringFormat='{}{0:HH:mm:ss}'}" Width="120" />
							<dg:DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="60" />
							<dg:DataGridTextColumn Header="Remote" Binding="{Binding Remote}" Width="*" />
						</dg:DataGrid.Columns>
					</dg:DataGrid>
				</DockPanel>
			</Border>

			<Border Grid.Column="1" Classes="card">
				<DockPanel>
					<TextBlock DockPanel.Dock="Top" Classes="h2" Text="Payload" />
					<TextBox Text="{Binding SelectedJson}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             Watermark="Select a log entry to view its payload." />
				</DockPanel>
			</Border>
		</Grid>

		<Border Grid.Row="1"
                Classes="card"
                MinHeight="220">
			<Grid RowDefinitions="Auto,*" RowSpacing="6">
				<StackPanel Orientation="Horizontal" Spacing="6">
					<TextBlock Classes="h2" Text="Debug" />
				</StackPanel>
				<ListBox Grid.Row="1"
                         ItemsSource="{Binding DebugLines}"
                         FontFamily="Consolas"
                         VerticalAlignment="Stretch" />
			</Grid>
		</Border>
	</Grid>
</UserControl>
