<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    xmlns:views="clr-namespace:ChatApplication.Views"
    mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="590"
    x:Class="ChatApplication.Views.ChatView">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0" Classes="card" Margin="10,10,10,4" Padding="12,10">
            <Grid ColumnDefinitions="Auto,12,Auto,12,*,12,Auto" VerticalAlignment="Center">

                <!-- Protocol selector -->
                <StackPanel Grid.Column="0" Spacing="3" Width="110">
                    <TextBlock Text="Protocol" FontSize="11" Opacity="0.6" />
                    <ComboBox ItemsSource="{Binding Protocols}"
                              SelectedItem="{Binding SelectedProtocol}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- Instance selector -->
                <StackPanel Grid.Column="2" Spacing="3" Width="160">
                    <TextBlock Text="Instance" FontSize="11" Opacity="0.6" />
                    <ComboBox ItemsSource="{Binding Instances}"
                              SelectedItem="{Binding SelectedInstance}"
                              DisplayMemberBinding="{Binding Name}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- Connection status -->
                <StackPanel Grid.Column="4" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="Status" FontSize="11" Opacity="0.6" />
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                    <Button Content="▶ Start"
                            Classes="theme-solid accent"
                            Click="StartServer_Click" />
                    <Button Content="■ Stop"
                            Classes="theme-outline"
                            Click="StopServer_Click" />
                    <Button Content="⟳ Connect"
                            Classes="theme-solid accent"
                            IsVisible="{Binding IsTcp}"
                            Click="Connect_Click" />
                    <Button Content="✕ Disconnect"
                            Classes="theme-outline"
                            IsVisible="{Binding IsTcp}"
                            Click="Disconnect_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Messages area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      Margin="10,4"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesItemsControl"
                          ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Full-width row; the bubble aligns itself inside -->
                        <Grid Margin="6,4">

                            <!-- Received bubble — left aligned -->
                            <Border HorizontalAlignment="Left"
                                    MaxWidth="460"
                                    IsVisible="{Binding IsReceived}"
                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16,16,16,4"
                                    Padding="14,9">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Remote}"
                                               FontSize="10"
                                               Opacity="0.55"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.55"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Border>

                            <!-- Sent bubble — right aligned -->
                            <Border HorizontalAlignment="Right"
                                    MaxWidth="460"
                                    IsVisible="{Binding IsSent}"
                                    Background="#5B8AF5"
                                    CornerRadius="16,16,4,16"
                                    Padding="14,9">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Foreground="White" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.7"
                                               HorizontalAlignment="Right"
                                               Foreground="White" />
                                </StackPanel>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Input bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Classes="card"
                Margin="10,4,10,10"
                Padding="10,8">
            <Grid ColumnDefinitions="*,10,Auto">
                <TextBox Grid.Column="0"
                         x:Name="MessageInput"
                         Text="{Binding MessageText}"
                         Watermark="Type a message…"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         KeyDown="MessageInput_KeyDown" />
                <Button Grid.Column="2"
                        Content="Send"
                        Classes="theme-solid accent"
                        Width="80"
                        Click="Send_Click" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
