<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="640"
    x:Class="ChatApplication.Views.ChatView">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header / Connection Controls ──────────────────────────── -->
        <Border Grid.Row="0"
                Classes="card"
                Margin="10,10,10,4"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <!-- Left: Config + Status -->
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">

                    <!-- Protocol -->
                    <StackPanel Spacing="4" Width="110" Margin="0,0,18,0">
                        <TextBlock Text="PROTOCOL"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Protocols}"
                                  SelectedItem="{Binding SelectedProtocol}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Instance -->
                    <StackPanel Spacing="4" Width="172" Margin="0,0,18,0">
                        <TextBlock Text="INSTANCE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Instances}"
                                  SelectedItem="{Binding SelectedInstance}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Status -->
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="STATUS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8"
                                     Fill="#22C55E"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Button Content="Start"
                            Classes="theme-solid accent"
                            Click="StartServer_Click" />
                    <Button Content="Stop"
                            Classes="theme-outline"
                            Click="StopServer_Click" />
                    <Button Content="Connect"
                            Classes="theme-solid accent"
                            IsVisible="{Binding IsTcp}"
                            Click="Connect_Click" />
                    <Button Content="Disconnect"
                            Classes="theme-outline"
                            IsVisible="{Binding IsTcp}"
                            Click="Disconnect_Click" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Messages area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      Margin="10,4"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesItemsControl"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,3">

                            <!-- Received bubble -->
                            <Border HorizontalAlignment="Left"
                                    MaxWidth="520"
                                    IsVisible="{Binding IsReceived}"
                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4,16,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Remote}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5" />
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.45"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Border>

                            <!-- Sent bubble -->
                            <Border HorizontalAlignment="Right"
                                    MaxWidth="520"
                                    IsVisible="{Binding IsSent}"
                                    Background="{DynamicResource ChatSentBubbleBrush}"
                                    CornerRadius="16,4,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20"
                                               Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.65"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                </StackPanel>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Input Bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Classes="card"
                Margin="10,4,10,10"
                Padding="12,10">
            <Grid ColumnDefinitions="*,10,Auto">
                <TextBox Grid.Column="0"
                         x:Name="MessageInput"
                         Text="{Binding MessageText}"
                         Watermark="Type a message and press Enter to send…"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         KeyDown="MessageInput_KeyDown" />
                <Button Grid.Column="2"
                        Content="Send"
                        Classes="theme-solid accent"
                        Width="84"
                        Click="Send_Click" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
