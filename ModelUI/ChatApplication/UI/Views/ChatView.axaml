<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
    mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="640"
    x:Class="ChatApplication.UI.Views.ChatView">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header / Connection Controls ──────────────────────────── -->
        <Border Grid.Row="0"
                Classes="card"
                Margin="10,10,10,4"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <!-- Left: Config + Status -->
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">

                    <!-- Protocol -->
                    <StackPanel Spacing="4" Width="110" Margin="0,0,18,0">
                        <TextBlock Text="PROTOCOL"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Protocols}"
                                  SelectedItem="{Binding SelectedProtocol}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Instance -->
                    <StackPanel Spacing="4" Width="172" Margin="0,0,18,0">
                        <TextBlock Text="INSTANCE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding Instances}"
                                  SelectedItem="{Binding SelectedInstance}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="36"
                               Fill="{actipro:ThemeResource Container2BorderBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />

                    <!-- Status -->
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="STATUS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8"
                                     Fill="#22C55E"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Button Content="Start"
                            Classes="theme-solid accent"
                            Click="StartServer_Click" />
                    <Button Content="Stop"
                            Classes="theme-outline"
                            Click="StopServer_Click" />
                    <Button Content="Connect"
                            Classes="theme-solid accent"
                            IsVisible="{Binding IsTcp}"
                            Click="Connect_Click" />
                    <Button Content="Disconnect"
                            Classes="theme-outline"
                            IsVisible="{Binding IsTcp}"
                            Click="Disconnect_Click" />
                    <Button Content="Clear Chat"
                            Classes="theme-outline"
                            Click="ClearChat_Click" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Messages area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      Margin="10,4"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesItemsControl"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,3">

                            <!-- Received bubble -->
                            <Border HorizontalAlignment="Left"
                                    MaxWidth="560"
                                    IsVisible="{Binding IsReceived}"
                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4,16,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">

                                    <!-- Type badge (hidden for plain messages) -->
                                    <Border IsVisible="{Binding HasTypeLabel}"
                                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Opacity="0.75" />
                                    </Border>

                                    <TextBlock Text="{Binding Remote}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.5" />
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20" />
                                    <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                               FontSize="10"
                                               Opacity="0.45"
                                               HorizontalAlignment="Right" />

                                    <!-- Yes / No response buttons -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="0,4,0,0"
                                                IsVisible="{Binding HasYesNoOptions}">
                                        <Button Content="Yes"
                                                Classes="theme-solid accent"
                                                Click="YesButton_Click" />
                                        <Button Content="No"
                                                Classes="theme-outline"
                                                Click="NoButton_Click" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Sent bubble -->
                            <Border HorizontalAlignment="Right"
                                    MaxWidth="560"
                                    IsVisible="{Binding IsSent}"
                                    Background="{DynamicResource ChatSentBubbleBrush}"
                                    CornerRadius="16,4,16,16"
                                    Padding="14,10">
                                <StackPanel Spacing="4">

                                    <!-- Type badge (hidden for plain messages) -->
                                    <Border IsVisible="{Binding HasTypeLabel}"
                                            Background="#20000000"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}"
                                                   Opacity="0.85" />
                                    </Border>

                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20"
                                               Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="4">
                                        <TextBlock Text="{Binding TimeStamp, StringFormat={}{0:HH:mm}}"
                                                   FontSize="10"
                                                   Opacity="0.65"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                        <TextBlock Text="✓ Delivered"
                                                   FontSize="10"
                                                   Opacity="0.75"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsDelivered}"
                                                   Foreground="{DynamicResource ChatSentBubbleTextBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Input Bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Classes="card"
                Margin="10,4,10,10"
                Padding="12,10">
            <Grid RowDefinitions="Auto,8,Auto">

                <!-- Row 0: Message type + RequiresYesNo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <StackPanel Spacing="3">
                        <TextBlock Text="MSG TYPE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.45" />
                        <ComboBox ItemsSource="{Binding MessageTypeNames}"
                                  SelectedItem="{Binding SelectedMessageTypeName}"
                                  Width="90" />
                    </StackPanel>
                    <CheckBox Content="Requires Yes/No"
                              IsChecked="{Binding RequiresYesNo}"
                              IsVisible="{Binding IsRequestMessageType}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,4" />
                </StackPanel>

                <!-- Row 2: Text input + Send -->
                <Grid Grid.Row="2" ColumnDefinitions="*,10,Auto">
                    <TextBox Grid.Column="0"
                             x:Name="MessageInput"
                             Text="{Binding MessageText}"
                             Watermark="Type a message and press Enter to send…"
                             AcceptsReturn="False"
                             VerticalContentAlignment="Center"
                             KeyDown="MessageInput_KeyDown" />
                    <Button Grid.Column="2"
                            Content="Send"
                            Classes="theme-solid accent"
                            Width="84"
                            Click="Send_Click" />
                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
